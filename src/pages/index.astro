---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Sigmion — Programmable Trust Layer for the Post Truth Era',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Get Started',
        href: '/#contact',
      },
    ]}
  >
    <Fragment slot="title">
      Programmable Trust Layer<br />for the Post Truth Era
    </Fragment>

    <Fragment slot="subtitle">
      Meet Cyfron — the solution that brings verifiable trust to every digital interaction.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Features"
    title="Features"
    items={[
      {
        title: 'Trust Policy Engine',
        description: 'Define custom trust policies that adapt to your security requirements in real-time.',
        icon: 'tabler:lock',
      },
      {
        title: 'Content Verification',
        description: 'Cryptographically verify the authenticity and integrity of digital content instantly.',
        icon: 'tabler:check',
      },
      {
        title: 'Instant Access',
        description: 'Zero-friction integration with millisecond-level decision latency for your systems.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Developer-Friendly APIs',
        description: 'Simple, powerful REST and WebSocket APIs with comprehensive documentation.',
        icon: 'tabler:code',
      },
      {
        title: 'Cross-Platform Support',
        description: 'Deploy Cyfron across web, mobile, desktop, and IoT environments seamlessly.',
        icon: 'tabler:device-desktop',
      },
      {
        title: 'Trust Analytics',
        description: 'Deep insights into trust patterns, anomalies, and verification metrics across your network.',
        icon: 'tabler:chart-bar',
      },
    ]}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    id="how-it-works"
    title="How It Works"
    items={[
      {
        title: '<span class="font-medium">Define</span>',
        description:
          'Set up your trust policies using our intuitive policy language. No cryptography expertise required.',
        icon: 'tabler:file-settings',
      },
      {
        title: '<span class="font-medium">Verify</span>',
        description: 'Submit content for verification. Cyfron validates against your policies in milliseconds.',
        icon: 'tabler:shield-check',
      },
      {
        title: '<span class="font-medium">Trust</span>',
        description: 'Receive cryptographic proof of trust. Build applications with confidence in verified data.',
        icon: 'tabler:lock-check',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Started Now',
        href: '/#contact',
      },
    ]}
  >
    <Fragment slot="title"> Start Verifying the World with Cyfron </Fragment>

    <Fragment slot="subtitle"> Join forward-thinking teams protecting digital trust </Fragment>
  </CallToAction>

  <!-- Contact Widget ************** -->

  <section id="contact" class="relative not-prose scroll-mt-[72px]">
    <div class="absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true">
      <div class="absolute inset-0 bg-blue-50 dark:bg-slate-900/50"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 md:px-6 py-16 md:py-24 lg:py-32 text-center">
      <h2 class="text-sm font-semibold mb-2">Contact</h2>
      <h1 class="text-3xl font-bold sm:text-4xl mb-4 dark:text-white">Get in Touch</h1>
      <p class="text-muted mb-8 text-lg">Get in touch to learn more</p>
      <div class="flex justify-center">
        <a
          href="mailto:contact@sigmion.global"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
          </svg>
          contact@sigmion.global
        </a>
      </div>
    </div>
  </section>
</Layout>
